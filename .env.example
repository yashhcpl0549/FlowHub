# Honasa Task Force - Environment Configuration
# Copy this file to .env and update values

# MongoDB Configuration
MONGO_URL=mongodb://mongodb:27017
DB_NAME=honasa_taskforce

# Frontend URL (used for building frontend)
REACT_APP_BACKEND_URL=http://localhost

# CORS Configuration
# For production, specify your domain(s)
CORS_ORIGINS=*

# Email Notifications (Optional)
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# GCS Storage Configuration (Optional)
# Leave empty to use local storage
GCS_BUCKET=
GCS_CREDENTIALS_PATH=

# Agent Queue Configuration
MAX_CONCURRENT_AGENTS=10
